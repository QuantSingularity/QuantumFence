# QuantumFence — Backend Environment Configuration
# Copy to .env and fill in your values

# ─── Core ────────────────────────────────────────────────────────────────────
APP_NAME=QuantumFence
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./quantumfence.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://qfuser:qfpass@localhost:5432/quantumfence

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── AI / Anthropic Claude ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_MODEL=claude-sonnet-4-20250514
THREAT_ANALYSIS_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.65

# ─── Detection Models ────────────────────────────────────────────────────────
YOLO_MODEL_PATH=ai_models/weights/yolov8n.pt
DRONE_MODEL_PATH=ai_models/weights/drone_detector.pt
DETECTION_CONFIDENCE=0.5
DETECTION_IOU_THRESHOLD=0.45
FRAME_SKIP=3
MAX_CAMERAS=64

# ─── Google Maps / Earth ─────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_EARTH_ENGINE_PROJECT=your-gee-project-id
DEFAULT_MAP_CENTER_LAT=33.6844
DEFAULT_MAP_CENTER_LNG=73.0479

# ─── Storage ─────────────────────────────────────────────────────────────────
SNAPSHOTS_DIR=snapshots
RECORDINGS_DIR=recordings
MAX_SNAPSHOT_AGE_DAYS=30

# ─── Email Notifications ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-smtp-password
ALERT_EMAIL_RECIPIENTS=["security@yourdomain.com"]

# ─── Stream ──────────────────────────────────────────────────────────────────
RTSP_TIMEOUT_SECONDS=10
STREAM_RECONNECT_ATTEMPTS=3
